# Floway self-hosted server configuration.
# Copy to apps/server/.env (gitignored) or export these in your shell / container.

# Admin key that protects the control-plane API and web console.
# Same role as the Cloudflare deployment's ADMIN_KEY.
ADMIN_KEY=change-me

# Free-form label surfaced in performance telemetry (origin/region name).
RUNTIME_LOCATION=self-hosted

# HTTP port the server listens on.
PORT=8788

# Directory holding all persistent state (SQLite db + spilled payload files).
# Mount this as a volume in production so data survives restarts.
DATA_DIR=./data

# SQLite database file path. Defaults to <DATA_DIR>/floway.db when unset.
# DB_PATH=./data/floway.db
